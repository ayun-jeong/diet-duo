# ── Gemini API ──────────────────────────────────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
# 음식 영양성분 AI 추정 + 운동 소모 칼로리 계산에 사용
GEMINI_API_KEY=AIzaSy...

# ── 식약처 식품영양성분 공공 API (선택) ───────────────────────────────────────
# https://www.data.go.kr 에서 "식품영양성분서비스" 신청 후 발급
# 설정하면 식약처 DB 우선 조회 → 없는 음식만 Gemini로 추정
FOOD_API_KEY=공공데이터포털키...

# ── Supabase (커플 공유 기능 사용 시 필수) ────────────────────────────────────
# https://supabase.com → 새 프로젝트 → Settings → API 에서 확인
# 미설정 시 커플 기능 없이 localStorage 전용 모드로 동작
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
